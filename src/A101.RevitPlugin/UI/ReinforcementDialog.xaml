<Window x:Class="A101.RevitPlugin.UI.ReinforcementDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="A101 — Автоматическое армирование"
        Width="520" Height="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12">
            Генерация дополнительного армирования
        </TextBlock>

        <!-- Isoline file selector -->
        <GroupBox Grid.Row="1" Header="Файл изолиний" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtIsolineFile" Grid.Column="0" IsReadOnly="True"
                         VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <Button x:Name="BtnBrowse" Grid.Column="1" Content="Обзор..."
                        Width="80" Click="BtnBrowse_Click"/>
            </Grid>
        </GroupBox>

        <!-- Slab parameters -->
        <GroupBox Grid.Row="2" Header="Параметры плиты" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Толщина, мм:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtThickness" Grid.Row="0" Grid.Column="1" Text="200" Margin="0,2"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Защитный слой, мм:" VerticalAlignment="Center"/>
                <TextBox x:Name="TxtCover" Grid.Row="1" Grid.Column="1" Text="25" Margin="0,2"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Класс бетона:" VerticalAlignment="Center"/>
                <ComboBox x:Name="CmbConcrete" Grid.Row="2" Grid.Column="1" SelectedIndex="2" Margin="0,2">
                    <ComboBoxItem Content="B15"/>
                    <ComboBoxItem Content="B20"/>
                    <ComboBoxItem Content="B25"/>
                    <ComboBoxItem Content="B30"/>
                    <ComboBoxItem Content="B35"/>
                    <ComboBoxItem Content="B40"/>
                </ComboBox>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Класс арматуры:" VerticalAlignment="Center"/>
                <ComboBox x:Name="CmbSteel" Grid.Row="3" Grid.Column="1" SelectedIndex="0" Margin="0,2">
                    <ComboBoxItem Content="A500C"/>
                    <ComboBoxItem Content="A400"/>
                    <ComboBoxItem Content="A240"/>
                    <ComboBoxItem Content="B500C"/>
                </ComboBox>
            </Grid>
        </GroupBox>

        <!-- Options -->
        <GroupBox Grid.Row="3" Header="Опции" Margin="0,0,0,8">
            <StackPanel>
                <CheckBox x:Name="ChkPlaceInRevit" Content="Разместить в модели Revit" IsChecked="True" Margin="0,2"/>
                <CheckBox x:Name="ChkCreateTags" Content="Создать марки" IsChecked="True" Margin="0,2"/>
                <CheckBox x:Name="ChkBendingDetails" Content="Создать ведомость деталей" IsChecked="True" Margin="0,2"/>
                <CheckBox x:Name="ChkOptimize" Content="Оптимизировать раскрой" IsChecked="True" Margin="0,2"/>
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <TextBlock Text="ML сервис:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox x:Name="TxtMlUrl" Width="200" Text="http://localhost:8101"/>
                    <CheckBox x:Name="ChkUseMl" Content="Использовать" IsChecked="False" Margin="8,0,0,0"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Supplier catalog -->
        <GroupBox Grid.Row="4" Header="Каталог поставщика (опционально)" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TxtCatalogFile" Grid.Column="0" IsReadOnly="True"
                         VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                <Button x:Name="BtnBrowseCatalog" Grid.Column="1" Content="Обзор..."
                        Width="80" Click="BtnBrowseCatalog_Click"/>
            </Grid>
        </GroupBox>

        <!-- Status / progress -->
        <GroupBox Grid.Row="5" Header="Статус">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TxtStatus" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                           Text="Выберите файл изолиний и нажмите «Выполнить»."/>
            </ScrollViewer>
        </GroupBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="BtnExecute" Content="Выполнить" Width="120" Height="32"
                    FontWeight="SemiBold" Click="BtnExecute_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnClose" Content="Закрыть" Width="80" Height="32"
                    Click="BtnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>
